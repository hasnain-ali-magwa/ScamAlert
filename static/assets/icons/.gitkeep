
<!DOCTYPE html>
<html lang="en">

<head>

    

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">


    <title>ScamAlert | AI Scam Detection</title>

    <meta name="title" content="ScamAlert">

    <meta
        name="description"
        content="Analyze suspicious messages and phishing links instantly using ScamAlert AI-powered scam detection.">

    <link rel="icon" type="image/png" href="assets/icons/favicon.png">


    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">


    <link rel="stylesheet" href="assets/css/style.css">
    <link rel="stylesheet" href="assets/css/responsive.css">
    <link rel="stylesheet" href="assets/css/animations.css">

</head>

<body>


    <div class="bg-grid"></div>

    <div class="bg-glow glow-1"></div>
    <div class="bg-glow glow-2"></div>

    <header class="navbar">

        <div class="container nav-container">

            <a href="#home" class="brand">
                ScamAlert
            </a>


            <nav class="nav-menu">

                <a href="#home" class="nav-link active">
                    Home
                </a>

                <a href="#contact" class="nav-link">
                    Contact Us
                </a>

                <a href="#portfolio" class="nav-link">
                    Dev Portfolio
                </a>


                <div class="nav-socials">

                    <a href="#" class="social-link">
                        <i class="fa-brands fa-github"></i>
                    </a>

                    <a href="#" class="social-link">
                        <i class="fa-brands fa-linkedin-in"></i>
                    </a>

                    <a href="#" class="social-link">
                        <i class="fa-brands fa-discord"></i>
                    </a>

                </div>

            </nav>


            <button class="hamburger">

                <span></span>
                <span></span>
                <span></span>

            </button>

        </div>

    </header>

    <section class="hero" id="home">

        <div class="container hero-container">

            <div class="hero-content">

                <span class="hero-badge">
                    AI-Powered Scam Detection
                </span>


                <h1 class="hero-title">
                    Stay Ahead of
                    <span>Online Scams</span>
                </h1>


                <p class="hero-description">
                    Analyze suspicious messages and phishing links instantly
                    using advanced AI-powered scam detection.
                </p>


                <div class="hero-buttons">

                    <a href="#analyzer" class="primary-btn">
                        Analyze Now
                    </a>

                    <a href="#features" class="secondary-btn">
                        Learn More
                    </a>

                </div>

            </div>

        </div>

    </section>


    <section class="analyzer" id="analyzer">

        <div class="container">

            <div class="section-header">

                <h2>
                    Smart Scam Analyzer
                </h2>

                <p>
                    Paste any suspicious message or phishing link.
                </p>

            </div>


            <div class="analyzer-card">

                <textarea
                    id="scamInput"
                    placeholder="Paste suspicious message or phishing link here..."></textarea>


                <button class="analyze-btn">
                    Analyze Threat
                </button>

            </div>


            <div class="result-card">

                <div class="result-top">

                    <span class="risk-badge high-risk">
                        High Risk
                    </span>

                    <span class="risk-score">
                        Scam Probability: 92%
                    </span>

                </div>


                <div class="result-content">

                    <h3>
                        Detected Issues
                    </h3>

                    <ul>

                        <li>Suspicious banking keywords</li>
                        <li>Urgency pressure tactics</li>
                        <li>Phishing URL detected</li>

                    </ul>

                </div>

            </div>

        </div>

    </section>


    <section class="features" id="features">

        <div class="container">

            <div class="section-header">

                <h2>
                    Features
                </h2>

                <p>
                    Powerful tools to protect you from online fraud.
                </p>

            </div>


            <div class="features-grid">

                <div class="feature-card">

                    <div class="feature-icon">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>

                    <h3>
                        Scam Detection
                    </h3>

                    <p>
                        Detect suspicious scam patterns instantly.
                    </p>

                </div>


                <div class="feature-card">

                    <div class="feature-icon">
                        <i class="fa-solid fa-link"></i>
                    </div>

                    <h3>
                        Phishing Check
                    </h3>

                    <p>
                        Analyze dangerous phishing links safely.
                    </p>

                </div>


                <div class="feature-card">

                    <div class="feature-icon">
                        <i class="fa-solid fa-bolt"></i>
                    </div>

                    <h3>
                        Fast Analysis
                    </h3>

                    <p>
                        Instant AI-powered threat analysis system.
                    </p>

                </div>

            </div>

        </div>

    </section>


    <section class="contact" id="contact">

        <div class="container">

            <div class="section-header">

                <h2>
                    Contact Us
                </h2>

                <p>
                    Send your feedback or report suspicious activity.
                </p>

            </div>


            <form class="contact-form">

                <input type="text" placeholder="Your Name" required>

                <input type="email" placeholder="Your Email" required>

                <textarea placeholder="Your Message" required></textarea>

                <button type="submit" class="primary-btn">
                    Send Message
                </button>

            </form>

        </div>

    </section>


    <footer class="footer" id="portfolio">

        <div class="container footer-container">

            <h2>
                ScamAlert
            </h2>

            <p>
                Stay Safe Online
            </p>


            <div class="footer-socials">

                <a href="#" class="social-link">
                    <i class="fa-brands fa-github"></i>
                </a>

                <a href="#" class="social-link">
                    <i class="fa-brands fa-linkedin-in"></i>
                </a>

                <a href="#" class="social-link">
                    <i class="fa-brands fa-discord"></i>
                </a>

                <a href="#" class="social-link">
                    <i class="fa-solid fa-globe"></i>
                </a>

            </div>


            <span class="copyright">
                © 2026 ScamAlert. All Rights Reserved.
            </span>

        </div>

    </footer>

    <script src="assets/js/main.js"></script>
    <script src="assets/js/responsive.js"></script>
    <script src="assets/js/animations.js"></script>

</body>

</html>
```
